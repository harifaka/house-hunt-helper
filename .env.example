# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=your-secret-key-here

# Database (SQLite — default)
DATABASE_PATH=./db/house_hunt.sqlite

# Database (PostgreSQL — uncomment to use instead of SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/house_hunt
# PGSSLMODE=disable
# DATABASE_SSL=false

# Logging / Audit
# Number of days to retain audit logs before automatic cleanup (default: 30)
LOG_RETENTION_DAYS=30

# AI Configuration (optional — can also be set via the admin UI)
# AI_PROVIDER=openai
# AI_ENDPOINT=https://api.openai.com/v1
# AI_MODEL=gpt-4
# AI_API_KEY=your-api-key-here
