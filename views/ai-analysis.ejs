<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
<div class="app">
  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <main class="main-content">

    <h1 class="mb-2">🤖 <%= t.ai_analysis %></h1>
    <p class="text-muted mb-6"><%= lang === 'en' ? 'Use AI to analyze inspection results' : 'AI használata a szemle eredmények elemzéséhez' %></p>

    <!-- Provider Info -->
    <div class="card mb-6">
      <div class="card__header d-flex justify-between items-center flex-wrap gap-2">
        <h3 class="card__title mb-0"><%= lang === 'en' ? 'AI Provider' : 'AI szolgáltató' %></h3>
        <a href="/admin" class="btn btn-sm btn-outline">⚙️ <%= t.settings %></a>
      </div>
      <div class="card__body">
        <% if (aiConfig.provider) { %>
          <p><strong><%= t.provider %>:</strong> <%= aiConfig.provider %></p>
          <p><strong><%= t.model %>:</strong> <%= aiConfig.model || 'N/A' %></p>
          <p><strong><%= t.endpoint %>:</strong> <%= aiConfig.endpoint || 'N/A' %></p>
        <% } else { %>
          <div class="text-center p-4">
            <p class="text-muted"><%= lang === 'en' ? 'AI is not configured yet.' : 'Az AI még nincs konfigurálva.' %></p>
            <a href="/admin" class="btn btn-primary mt-2">⚙️ <%= lang === 'en' ? 'Configure AI' : 'AI konfigurálás' %></a>
          </div>
        <% } %>
      </div>
    </div>

    <% if (aiConfig.provider) { %>
    <!-- House Selection -->
    <div class="card mb-6">
      <div class="card__header">
        <h3 class="card__title mb-0"><%= lang === 'en' ? 'Select House' : 'Válassz házat' %></h3>
      </div>
      <div class="card__body">
        <% if (houses.length === 0) { %>
          <p class="text-muted"><%= t.no_houses %></p>
        <% } else { %>
          <select id="ai-house" class="form-control mb-4" style="max-width:400px;">
            <option value=""><%= lang === 'en' ? '— Select house —' : '— Válassz házat —' %></option>
            <% houses.forEach(function(h) { %>
              <option value="<%= h.id %>" <%= typeof selectedHouse !== 'undefined' && selectedHouse === h.id ? 'selected' : '' %>><%= h.name %><%= h.address ? ' — ' + h.address : '' %></option>
            <% }); %>
          </select>

          <!-- Analysis Options -->
          <div class="mb-4">
            <label class="form-label"><%= lang === 'en' ? 'Analysis Options' : 'Elemzési opciók' %></label>
            <div class="d-flex flex-wrap gap-3">
              <label class="d-flex items-center gap-2">
                <input type="checkbox" id="opt-condition" checked>
                <%= lang === 'en' ? 'Overall condition assessment' : 'Általános állapotértékelés' %>
              </label>
              <label class="d-flex items-center gap-2">
                <input type="checkbox" id="opt-cost" checked>
                <%= lang === 'en' ? 'Cost estimation review' : 'Költségbecslés áttekintése' %>
              </label>
              <label class="d-flex items-center gap-2">
                <input type="checkbox" id="opt-priority" checked>
                <%= lang === 'en' ? 'Priority recommendations' : 'Prioritási javaslatok' %>
              </label>
              <label class="d-flex items-center gap-2">
                <input type="checkbox" id="opt-images">
                <%= lang === 'en' ? 'Image analysis (if available)' : 'Képelemzés (ha elérhető)' %>
              </label>
            </div>
          </div>

          <button type="button" class="btn btn-primary btn-lg" id="run-analysis">
            🚀 <%= t.analyze %>
          </button>
        <% } %>
      </div>
    </div>

    <!-- Status / Notification Area -->
    <div class="card mb-6" id="status-card" style="display:none;">
      <div class="card__header">
        <h3 class="card__title mb-0"><%= lang === 'en' ? 'Analysis Status' : 'Elemzés állapota' %></h3>
      </div>
      <div class="card__body">
        <div id="ai-status"></div>
      </div>
    </div>

    <!-- Previous Reports -->
    <div class="card mb-6" id="reports-card" style="display:none;">
      <div class="card__header">
        <h3 class="card__title mb-0"><%= lang === 'en' ? 'AI Reports' : 'AI jelentések' %></h3>
      </div>
      <div class="card__body" id="reports-list">
      </div>
    </div>

    <!-- Report Detail View -->
    <div class="card mb-6" id="report-detail-card" style="display:none;">
      <div class="card__header d-flex justify-between items-center">
        <h3 class="card__title mb-0"><%= lang === 'en' ? 'Report Detail' : 'Jelentés részletei' %></h3>
        <button class="btn btn-sm btn-ghost" onclick="document.getElementById('report-detail-card').style.display='none'">✕</button>
      </div>
      <div class="card__body" id="report-detail"></div>
    </div>
    <% } %>

    <%- include('partials/footer') %>
  </main>
</div>
<%- include('partials/scripts') %>
<script>
(function() {
  var runBtn = document.getElementById('run-analysis');
  var houseSelect = document.getElementById('ai-house');
  if (!runBtn || !houseSelect) return;

  var pollTimer = null;
  var lang = '<%= lang %>';

  // Load reports when house is selected
  houseSelect.addEventListener('change', function() {
    if (this.value) loadReports(this.value);
  });

  // Auto-load if house pre-selected
  if (houseSelect.value) loadReports(houseSelect.value);

  runBtn.addEventListener('click', function() {
    var houseId = houseSelect.value;
    if (!houseId) {
      alert(lang === 'en' ? 'Please select a house' : 'Kérlek válassz házat');
      return;
    }

    var statusCard = document.getElementById('status-card');
    var statusDiv = document.getElementById('ai-status');
    statusCard.style.display = 'block';
    statusDiv.innerHTML = '<div class="d-flex items-center gap-3"><div class="spinner"></div><span>' +
      (lang === 'en' ? 'Starting AI analysis... This may take a few minutes.' : 'AI elemzés indítása... Ez néhány percig tarthat.') +
      '</span></div>';
    runBtn.disabled = true;

    fetch('/api/ai/analyze/' + houseId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({})
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) {
        runBtn.disabled = false;
        statusDiv.innerHTML = '<p style="color:var(--danger)">❌ ' + data.error + '</p>';
        return;
      }

      statusDiv.innerHTML = '<div class="d-flex items-center gap-3"><div class="spinner"></div><span>' +
        (lang === 'en' ? 'Analysis in progress... Generating section-by-section report.' : 'Elemzés folyamatban... Részletenkénti jelentés generálása.') +
        '</span></div>';

      // Start polling for completion
      startPolling(houseId);
    })
    .catch(function(err) {
      runBtn.disabled = false;
      statusDiv.innerHTML = '<p style="color:var(--danger)">❌ ' + err.message + '</p>';
    });
  });

  function startPolling(houseId) {
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(function() {
      fetch('/api/ai/reports/' + houseId)
        .then(function(r) { return r.json(); })
        .then(function(reports) {
          if (reports.length > 0) {
            var latest = reports[0];
            if (latest.status === 'completed') {
              clearInterval(pollTimer);
              pollTimer = null;
              runBtn.disabled = false;

              var statusDiv = document.getElementById('ai-status');
              statusDiv.innerHTML = '<div class="alert alert-success"><strong>✅ ' +
                (lang === 'en' ? 'Analysis complete!' : 'Elemzés kész!') +
                '</strong></div>';

              loadReports(houseId);
              showReportDetail(latest.id);
            } else if (latest.status === 'failed') {
              clearInterval(pollTimer);
              pollTimer = null;
              runBtn.disabled = false;

              var statusDiv2 = document.getElementById('ai-status');
              statusDiv2.innerHTML = '<div class="alert alert-danger"><strong>❌ ' +
                (lang === 'en' ? 'Analysis failed' : 'Az elemzés sikertelen') +
                '</strong></div>';
            }
          }
        });
    }, 3000);
  }

  function loadReports(houseId) {
    fetch('/api/ai/reports/' + houseId)
      .then(function(r) { return r.json(); })
      .then(function(reports) {
        var reportsCard = document.getElementById('reports-card');
        var reportsList = document.getElementById('reports-list');

        if (reports.length === 0) {
          reportsCard.style.display = 'none';
          return;
        }

        reportsCard.style.display = 'block';
        var html = '';
        reports.forEach(function(r) {
          var statusBadge = r.status === 'completed'
            ? '<span class="badge badge--success">\u2705 ' + (lang === 'en' ? 'Completed' : 'Kész') + '</span>'
            : r.status === 'generating'
              ? '<span class="badge badge--warning">\u23f3 ' + (lang === 'en' ? 'Generating' : 'Generálás') + '</span>'
              : '<span class="badge badge--danger">\u274c ' + (lang === 'en' ? 'Failed' : 'Sikertelen') + '</span>';

          html += '<div class="d-flex justify-between items-center mb-3" style="padding:var(--sp-3);background:var(--gray-50);border-radius:var(--radius);">' +
            '<div>' +
              '<div class="d-flex items-center gap-2 mb-1">' + statusBadge + ' <span class="text-xs text-muted">' + escapeHtml(r.created_at) + '</span></div>' +
              (r.summary ? '<div class="text-sm" style="max-width:600px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + escapeHtml(r.summary.substring(0, 120)) + '...</div>' : '') +
            '</div>' +
            (r.status === 'completed' ? '<button class="btn btn-sm btn-outline-primary" data-report-id="' + escapeHtml(r.id) + '">' + (lang === 'en' ? 'View' : 'Megtekintés') + '</button>' : '') +
          '</div>';
        });

        reportsList.innerHTML = html;

        // Attach event listeners via delegation
        reportsList.querySelectorAll('[data-report-id]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            showReportDetail(this.getAttribute('data-report-id'));
          });
        });
      });
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function showReportDetail(reportId) {
    fetch('/api/ai/report/' + reportId)
      .then(function(r) { return r.json(); })
      .then(function(report) {
        var card = document.getElementById('report-detail-card');
        var detail = document.getElementById('report-detail');
        card.style.display = 'block';

        var html = '<div class="text-xs text-muted mb-3">' +
          (lang === 'en' ? 'Generated' : 'Generálva') + ': ' + escapeHtml(report.created_at) + '</div>';

        if (report.summary) {
          html += '<div class="mb-4"><h4 class="mb-2">' + (lang === 'en' ? 'Summary' : 'Összefoglaló') + '</h4>' +
            '<div style="line-height:1.7;text-align:justify;">' + escapeHtml(report.summary).replace(/\n/g, '<br>') + '</div></div>';
        }

        if (report.sections && report.sections.length > 0) {
          html += '<h4 class="mb-2">' + (lang === 'en' ? 'Detailed Sections' : 'Részletes szekciók') + '</h4>';
          report.sections.forEach(function(sec) {
            html += '<details class="mb-3" open><summary class="font-bold" style="cursor:pointer;padding:var(--sp-2) 0;">' +
              escapeHtml(sec.section_name) + '</summary>' +
              '<div style="padding:var(--sp-3);background:var(--gray-50);border-radius:var(--radius);line-height:1.7;text-align:justify;">' +
              escapeHtml(sec.report_text).replace(/\n/g, '<br>') + '</div></details>';
          });
        }

        detail.innerHTML = html;
        card.scrollIntoView({ behavior: 'smooth' });
      });
  }
})();
</script>
<style>
.spinner {
  width: 24px; height: 24px;
  border: 3px solid var(--gray-300);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>
</body>
</html>
