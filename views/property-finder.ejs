<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
<div class="app">
  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <main class="main-content">

    <!-- Hero Section -->
    <section class="pf-hero">
      <div class="pf-hero__bg" style="background-image: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=1600&q=80')"></div>
      <div class="pf-hero__overlay"></div>
      <div class="pf-hero__content">
        <h1 class="pf-hero__title"><%= lang === 'en' ? 'Property Finder' : 'Ingatlan Kereső' %></h1>
        <p class="pf-hero__subtitle"><%= lang === 'en' ? 'Scrape, analyze, and compare properties from ingatlan.com' : 'Ingatlanok keresése, elemzése és összehasonlítása az ingatlan.com-ról' %></p>
      </div>
    </section>

    <!-- Scrape URL Section -->
    <section class="pf-section">
      <div class="card pf-card">
        <div class="card__header">
          <h3 class="card__title">🔗 <%= lang === 'en' ? 'Scrape Property' : 'Ingatlan beolvasása' %></h3>
        </div>
        <div class="card__body">
          <p class="text-muted mb-3"><%= lang === 'en' ? 'Paste an ingatlan.com listing URL to scrape property details, images, and generate a pre-inspection analysis.' : 'Illessz be egy ingatlan.com hirdetés URL-t az ingatlan adatainak, képeinek és előzetes elemzésének beolvasásához.' %></p>
          <div class="d-flex gap-2 flex-wrap">
            <input type="url" id="scrape-url" class="form-control" style="flex:1; min-width: 300px;"
                   placeholder="https://ingatlan.com/..." />
            <button class="btn btn-primary" id="btn-scrape" onclick="scrapeProperty()">
              🔍 <%= lang === 'en' ? 'Scrape' : 'Beolvasás' %>
            </button>
            <button class="btn btn-accent" id="btn-scrape-demo" onclick="scrapeDemoProperty()">
              🎭 Demo
            </button>
          </div>
          <div id="scrape-status" class="mt-3" style="display:none;"></div>
        </div>
      </div>
    </section>

    <!-- City Search Section -->
    <section class="pf-section">
      <div class="card pf-card">
        <div class="card__header">
          <h3 class="card__title">🏙️ <%= lang === 'en' ? 'City Market Analysis' : 'Városi piacelemzés' %></h3>
        </div>
        <div class="card__body">
          <p class="text-muted mb-3"><%= lang === 'en' ? 'Search for all listed properties in a city to calculate average and median prices.' : 'Keress rá egy város összes hirdetésére az átlag és medián árak kiszámításához.' %></p>
          <div class="d-flex gap-2 flex-wrap">
            <input type="text" id="city-name" class="form-control" style="flex:1; min-width: 200px;"
                   placeholder="<%= lang === 'en' ? 'e.g. Budapest, Debrecen...' : 'pl. Budapest, Debrecen...' %>" />
            <button class="btn btn-primary" id="btn-city-search" onclick="searchCityListings()">
              🔎 <%= lang === 'en' ? 'Search' : 'Keresés' %>
            </button>
            <button class="btn btn-accent" id="btn-city-demo" onclick="searchCityDemo()">
              🎭 Demo
            </button>
          </div>
          <div id="city-results" class="mt-3" style="display:none;"></div>
        </div>
      </div>
    </section>

    <!-- Scraped Properties -->
    <% if (properties.length > 0) { %>
    <section class="pf-section">
      <div class="d-flex justify-between items-center mb-4">
        <h2>🏡 <%= lang === 'en' ? 'Scraped Properties' : 'Beolvasott ingatlanok' %> (<%= properties.length %>)</h2>
        <button class="btn btn-accent" onclick="openReportModal()">
          📄 <%= lang === 'en' ? 'Create Report' : 'Jelentés készítése' %>
        </button>
      </div>
      <div class="grid grid-3">
        <% properties.forEach(function(prop) { %>
          <% var imgs = []; try { imgs = JSON.parse(prop.image_urls || '[]'); } catch(e) {} %>
          <div class="card card--house pf-property-card animate-slide-up">
            <% if (imgs.length > 0) { %>
              <div class="pf-property-card__image">
                <img src="<%= imgs[0] %>" alt="<%= prop.title %>" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=400'" />
                <% if (imgs.length > 1) { %>
                  <span class="pf-property-card__badge">📷 <%= imgs.length %></span>
                <% } %>
              </div>
            <% } %>
            <div class="card__body">
              <h4 class="card__title mb-1 truncate"><%= prop.title || 'Untitled' %></h4>
              <% if (prop.location) { %><p class="text-muted text-sm mb-1">📍 <%= prop.location %></p><% } %>
              <% if (prop.price) { %><p class="font-bold text-primary mb-1">💰 <%= Number(prop.price).toLocaleString() %> Ft</p><% } %>
              <div class="d-flex gap-2 text-sm text-muted mb-2">
                <% if (prop.size_sqm) { %><span>📐 <%= prop.size_sqm %> m²</span><% } %>
                <% if (prop.rooms) { %><span>🛏️ <%= prop.rooms %> <%= lang === 'en' ? 'rooms' : 'szoba' %></span><% } %>
              </div>
              <% if (prop.llm_analysis) { %>
                <span class="badge badge--success text-xs">✅ <%= lang === 'en' ? 'Analyzed' : 'Elemezve' %></span>
              <% } %>
            </div>
            <div class="card__footer d-flex flex-wrap gap-2">
              <a href="/property-finder/property/<%= prop.id %>" class="btn btn-sm btn-primary">📋 <%= lang === 'en' ? 'Details' : 'Részletek' %></a>
              <button class="btn btn-sm btn-accent" onclick="analyzeProperty('<%= prop.id %>')">🤖 <%= lang === 'en' ? 'Analyze' : 'Elemzés' %></button>
              <input type="checkbox" class="report-checkbox" value="<%= prop.id %>" title="<%= lang === 'en' ? 'Include in report' : 'Hozzáadás a jelentéshez' %>" />
            </div>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- City Information -->
    <% if (cities.length > 0) { %>
    <section class="pf-section">
      <h2 class="mb-4">🏙️ <%= lang === 'en' ? 'City Data' : 'Városi adatok' %></h2>
      <div class="grid grid-2">
        <% cities.forEach(function(city) { %>
          <div class="card pf-city-card animate-slide-up">
            <div class="card__header">
              <h4 class="card__title">📍 <%= city.city_name %></h4>
            </div>
            <div class="card__body">
              <% if (city.population) { %><p class="text-sm">👥 <%= lang === 'en' ? 'Population' : 'Lakosság' %>: <strong><%= Number(city.population).toLocaleString() %></strong></p><% } %>
              <% if (city.avg_price) { %><p class="text-sm">📊 <%= lang === 'en' ? 'Avg Price' : 'Átlagár' %>: <strong><%= Number(city.avg_price).toLocaleString() %> Ft</strong></p><% } %>
              <% if (city.median_price) { %><p class="text-sm">📈 <%= lang === 'en' ? 'Median Price' : 'Medián ár' %>: <strong><%= Number(city.median_price).toLocaleString() %> Ft</strong></p><% } %>
              <% if (city.security_info) { %><p class="text-sm">🛡️ <%= city.security_info.substring(0, 80) %>...</p><% } %>
              <% if (city.current_mayor) { %><p class="text-sm">🏛️ <%= lang === 'en' ? 'Mayor' : 'Polgármester' %>: <%= city.current_mayor %></p><% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- Reports -->
    <% if (reports.length > 0) { %>
    <section class="pf-section">
      <h2 class="mb-4">📄 <%= lang === 'en' ? 'Reports' : 'Jelentések' %></h2>
      <div class="grid grid-3">
        <% reports.forEach(function(report) { %>
          <div class="card animate-slide-up">
            <div class="card__body">
              <h4 class="card__title mb-1"><%= report.title %></h4>
              <% if (report.city) { %><p class="text-muted text-sm">📍 <%= report.city %></p><% } %>
              <p class="text-xs text-muted"><%= new Date(report.created_at).toLocaleDateString() %></p>
            </div>
            <div class="card__footer d-flex gap-2">
              <a href="/property-finder/report/<%= report.id %>" class="btn btn-sm btn-primary">👁️ <%= lang === 'en' ? 'View' : 'Megtekintés' %></a>
              <a href="/property-finder/report/<%= report.id %>/pdf" class="btn btn-sm btn-accent">📥 PDF</a>
              <form method="POST" action="/property-finder/report/<%= report.id %>/delete" style="display:inline;" onsubmit="return confirm('<%= lang === 'en' ? 'Delete this report?' : 'Törli ezt a jelentést?' %>')">
                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- Report Creation Modal -->
    <div class="modal-overlay" id="report-modal">
      <div class="modal">
        <div class="modal__header">
          <h3 class="modal__title"><%= lang === 'en' ? 'Create Comparison Report' : 'Összehasonlító jelentés készítése' %></h3>
          <button class="modal__close" onclick="document.getElementById('report-modal').classList.remove('is-active')">&times;</button>
        </div>
        <div class="modal__body">
          <div class="form-group">
            <label class="form-label"><%= lang === 'en' ? 'Report Title' : 'Jelentés címe' %></label>
            <input type="text" id="report-title" class="form-control" placeholder="<%= lang === 'en' ? 'e.g. Budapest Houses Q1 2025' : 'pl. Budapest házak 2025 Q1' %>" />
          </div>
          <p class="text-sm text-muted" id="report-selected-count"><%= lang === 'en' ? 'Select properties using checkboxes' : 'Válassz ingatlanokat a jelölőnégyzetekkel' %></p>
        </div>
        <div class="modal__footer">
          <button class="btn btn-secondary" onclick="document.getElementById('report-modal').classList.remove('is-active')"><%= lang === 'en' ? 'Cancel' : 'Mégse' %></button>
          <button class="btn btn-accent" onclick="createReport()"><%= lang === 'en' ? 'Generate Report' : 'Jelentés generálása' %></button>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>
  </main>
</div>
<%- include('partials/scripts') %>
<script>
var langEn = '<%= lang %>' === 'en';

async function scrapeProperty() {
  var url = document.getElementById('scrape-url').value.trim();
  if (!url) return alert(langEn ? 'Enter URL' : 'Add meg az URL-t');
  showStatus('scrape-status', langEn ? 'Scraping...' : 'Beolvasás...', 'info');
  try {
    var resp = await fetch('/property-finder/scrape', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({url}) });
    var data = await resp.json();
    if (data.success) {
      showStatus('scrape-status', (langEn ? 'Property scraped successfully!' : 'Ingatlan sikeresen beolvasva!') + (data.cached ? (langEn ? ' (cached)' : ' (gyorsítótárból)') : ''), 'success');
      setTimeout(function() { window.location.reload(); }, 1000);
    } else {
      showStatus('scrape-status', data.error || 'Error', 'danger');
    }
  } catch(e) {
    showStatus('scrape-status', e.message, 'danger');
  }
}

async function scrapeDemoProperty() {
  var url = document.getElementById('scrape-url').value.trim() || 'https://ingatlan.com/demo/' + Date.now();
  showStatus('scrape-status', langEn ? 'Loading demo data...' : 'Demo adatok betöltése...', 'info');
  try {
    var resp = await fetch('/property-finder/scrape-demo', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({url}) });
    var data = await resp.json();
    if (data.success) {
      showStatus('scrape-status', langEn ? 'Demo property loaded!' : 'Demo ingatlan betöltve!', 'success');
      setTimeout(function() { window.location.reload(); }, 1000);
    } else {
      showStatus('scrape-status', data.error || 'Error', 'danger');
    }
  } catch(e) {
    showStatus('scrape-status', e.message, 'danger');
  }
}

async function searchCityListings() {
  var city = document.getElementById('city-name').value.trim();
  if (!city) return alert(langEn ? 'Enter city' : 'Add meg a várost');
  showStatus('city-results', langEn ? 'Searching...' : 'Keresés...', 'info');
  document.getElementById('city-results').style.display = 'block';
  try {
    var resp = await fetch('/property-finder/search-city', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({city, maxPages: 1}) });
    var data = await resp.json();
    if (data.success) {
      showCityResults(data);
    } else {
      showStatus('city-results', data.error || 'Error', 'danger');
    }
  } catch(e) {
    showStatus('city-results', e.message, 'danger');
  }
}

async function searchCityDemo() {
  var city = document.getElementById('city-name').value.trim() || 'Budapest';
  document.getElementById('city-name').value = city;
  showStatus('city-results', langEn ? 'Loading demo data...' : 'Demo adatok betöltése...', 'info');
  document.getElementById('city-results').style.display = 'block';
  try {
    var resp = await fetch('/property-finder/search-city-demo', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({city}) });
    var data = await resp.json();
    if (data.success) {
      showCityResults(data);
      setTimeout(function() { window.location.reload(); }, 2000);
    } else {
      showStatus('city-results', data.error || 'Error', 'danger');
    }
  } catch(e) {
    showStatus('city-results', e.message, 'danger');
  }
}

function showCityResults(data) {
  var el = document.getElementById('city-results');
  el.style.display = 'block';
  var html = '<div class="pf-stats-grid">';
  html += '<div class="pf-stat-card"><div class="pf-stat-card__value">' + data.results.length + '</div><div class="pf-stat-card__label">' + (langEn ? 'Listings' : 'Hirdetés') + '</div></div>';
  if (data.stats) {
    html += '<div class="pf-stat-card"><div class="pf-stat-card__value">' + formatPrice(data.stats.avg) + '</div><div class="pf-stat-card__label">' + (langEn ? 'Average Price' : 'Átlagár') + '</div></div>';
    html += '<div class="pf-stat-card"><div class="pf-stat-card__value">' + formatPrice(data.stats.median) + '</div><div class="pf-stat-card__label">' + (langEn ? 'Median Price' : 'Medián ár') + '</div></div>';
    html += '<div class="pf-stat-card"><div class="pf-stat-card__value">' + formatPrice(data.stats.min) + ' - ' + formatPrice(data.stats.max) + '</div><div class="pf-stat-card__label">' + (langEn ? 'Price Range' : 'Ártartomány') + '</div></div>';
  }
  html += '</div>';

  if (data.cityInfo) {
    html += '<div class="pf-city-info mt-4">';
    html += '<h4>🏙️ ' + data.city + '</h4>';
    if (data.cityInfo.population) html += '<p>👥 ' + (langEn ? 'Population' : 'Lakosság') + ': <strong>' + Number(data.cityInfo.population).toLocaleString() + '</strong></p>';
    if (data.cityInfo.securityInfo) html += '<p>🛡️ ' + data.cityInfo.securityInfo + '</p>';
    if (data.cityInfo.infrastructure) html += '<p>🏗️ ' + data.cityInfo.infrastructure + '</p>';
    if (data.cityInfo.currentMayor) html += '<p>🏛️ ' + (langEn ? 'Mayor' : 'Polgármester') + ': ' + data.cityInfo.currentMayor + '</p>';
    if (data.cityInfo.previousMayor) html += '<p>📜 ' + (langEn ? 'Previous Mayor' : 'Előző polgármester') + ': ' + data.cityInfo.previousMayor + '</p>';
    if (data.cityInfo.generalInfo) html += '<p>ℹ️ ' + data.cityInfo.generalInfo + '</p>';
    html += '</div>';
  }

  el.innerHTML = html;
}

async function analyzeProperty(id) {
  if (!confirm(langEn ? 'Run AI analysis on this property?' : 'Futtatja az AI elemzést erre az ingatlanra?')) return;
  try {
    var resp = await fetch('/property-finder/analyze/' + id, { method: 'POST', headers: {'Content-Type':'application/json'} });
    var data = await resp.json();
    if (data.success) {
      alert(langEn ? 'Analysis complete! Refresh to see results.' : 'Elemzés kész! Frissítsen az eredmények megtekintéséhez.');
      window.location.reload();
    } else {
      alert(data.error || 'Analysis failed');
    }
  } catch(e) {
    alert(e.message);
  }
}

function openReportModal() {
  var checked = document.querySelectorAll('.report-checkbox:checked');
  var count = checked.length;
  document.getElementById('report-selected-count').textContent = count + (langEn ? ' properties selected' : ' ingatlan kiválasztva');
  document.getElementById('report-modal').classList.add('is-active');
}

async function createReport() {
  var checked = document.querySelectorAll('.report-checkbox:checked');
  var ids = Array.from(checked).map(function(cb) { return cb.value; });
  if (ids.length === 0) return alert(langEn ? 'Select at least one property' : 'Válassz legalább egy ingatlant');
  var title = document.getElementById('report-title').value.trim() || (langEn ? 'Property Report' : 'Ingatlan jelentés');

  try {
    var resp = await fetch('/property-finder/report', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ title: title, propertyIds: ids }) });
    var data = await resp.json();
    if (data.success) {
      window.location.href = '/property-finder/report/' + data.reportId;
    } else {
      alert(data.error || 'Error');
    }
  } catch(e) {
    alert(e.message);
  }
}

function showStatus(elId, msg, type) {
  var el = document.getElementById(elId);
  el.style.display = 'block';
  el.innerHTML = '<div class="alert alert-' + type + '">' + msg + '</div>';
}

function formatPrice(num) {
  if (!num) return '—';
  if (num >= 1000000) return (num / 1000000).toFixed(1) + ' M Ft';
  return Number(num).toLocaleString() + ' Ft';
}

// Close modal on overlay click
document.getElementById('report-modal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('is-active');
});
</script>
</body>
</html>
