<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
<div class="app">
  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <main class="main-content">

    <!-- Breadcrumb -->
    <div class="mb-4">
      <a href="/houses" class="btn btn-ghost btn-sm">← <%= t.back_to_houses %></a>
    </div>

    <!-- House Info Header -->
    <div class="card mb-6 animate-fade-in">
      <div class="card__header d-flex justify-between items-center flex-wrap gap-3">
        <div>
          <h1 class="card__title mb-1"><%= house.name %></h1>
          <% if (house.source === 'scraped') { %>
            <span class="badge badge--info text-xs"><%= lang === 'en' ? 'Scraped' : 'Begyűjtve' %></span>
          <% } %>
          <% if (house.address) { %>
            <p class="text-muted text-sm">📍 <%= house.address %></p>
          <% } %>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <button class="btn btn-sm btn-outline-primary" onclick="document.getElementById('edit-house-modal').classList.add('is-active')">
            ✏️ <%= t.edit %>
          </button>
          <form method="POST" action="/houses/<%= house.id %>/delete" style="display:inline;"
                onsubmit="return confirm('<%= t.confirm_delete %>')">
            <button type="submit" class="btn btn-sm btn-danger">🗑️ <%= t.delete %></button>
          </form>
        </div>
      </div>
      <div class="card__body">
        <div class="d-flex flex-wrap gap-4">
          <% if (house.asking_price) { %>
            <div>
              <span class="text-xs text-muted uppercase"><%= t.asking_price_label %></span>
              <p class="font-bold text-lg"><%= Number(house.asking_price).toLocaleString() %> Ft</p>
            </div>
          <% } %>
          <div>
            <span class="text-xs text-muted uppercase"><%= t.created %></span>
            <p class="font-medium"><%= new Date(house.created_at).toLocaleDateString() %></p>
          </div>
          <div>
            <span class="text-xs text-muted uppercase"><%= t.progress %></span>
            <p class="font-medium"><%= house.answeredCount %> / <%= house.totalQuestions %> (<%= house.progress %>%)</p>
          </div>
        </div>
        <% if (house.notes) { %>
          <div class="mt-4">
            <span class="text-xs text-muted uppercase"><%= t.notes %></span>
            <p class="mt-1"><%= house.notes %></p>
          </div>
        <% } %>
        <% if (house.description) { %>
          <div class="mt-4">
            <span class="text-xs text-muted uppercase"><%= lang === 'en' ? 'Description' : 'Leírás' %></span>
            <p class="mt-1" style="white-space:pre-wrap;"><%= house.description %></p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- House Images Gallery -->
    <div class="card mb-6 animate-fade-in">
      <div class="card__header d-flex justify-between items-center flex-wrap gap-2">
        <h3 class="card__title mb-0">📸 <%= lang === 'en' ? 'Photos' : 'Fotók' %></h3>
        <button class="btn btn-sm btn-accent" onclick="document.getElementById('upload-image-modal').classList.add('is-active')">
          ➕ <%= lang === 'en' ? 'Add Photo' : 'Fotó hozzáadása' %>
        </button>
      </div>
      <div class="card__body">
        <% if (images && images.length > 0) { %>
          <div class="image-gallery">
            <% images.forEach(function(img) { %>
              <div class="image-gallery__item">
                <img src="/uploads/<%= img.filename %>" alt="<%= img.caption || house.name %>" class="image-gallery__img">
                <% if (img.caption) { %>
                  <div class="image-gallery__caption"><%= img.caption %></div>
                <% } %>
                <form method="POST" action="/houses/<%= house.id %>/delete-image/<%= img.id %>" class="image-gallery__delete"
                      onsubmit="return confirm('<%= lang === 'en' ? 'Delete this photo?' : 'Törli ezt a fotót?' %>')">
                  <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                </form>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-muted text-sm"><%= lang === 'en' ? 'No photos yet. Add photos to document this property.' : 'Még nincsenek fotók. Adjon hozzá fotókat az ingatlan dokumentálásához.' %></p>
        <% } %>
      </div>
    </div>

    <!-- Score Overview -->
    <%
      var scoreLevel = 'low';
      if (house.overallScore >= 75) scoreLevel = 'great';
      else if (house.overallScore >= 50) scoreLevel = 'good';
      else if (house.overallScore >= 25) scoreLevel = 'medium';

      var recLabel = t.critical_issues;
      var recClass = 'alert-danger';
      if (house.overallScore >= 75) { recLabel = t.good_condition; recClass = 'alert-success'; }
      else if (house.overallScore >= 50) { recLabel = t.needs_attention; recClass = 'alert-warning'; }
    %>

    <% if (house.answeredCount > 0) { %>
      <div class="results-hero mb-6 animate-slide-up">
        <div class="results-hero__score"><%= house.overallScore %>%</div>
        <div class="results-hero__label"><%= t.overall_score %></div>
      </div>

      <% if (house.progress > 0) { %>
        <div class="alert <%= recClass %> mb-6">
          <div class="alert__title"><%= t.recommendation %></div>
          <p><%= recLabel %></p>
        </div>
      <% } %>
    <% } %>

    <!-- Action Buttons -->
    <div class="d-flex flex-wrap gap-3 mb-6">
      <% if (house.progress < 100) { %>
        <a href="/quiz/<%= house.id %>" class="btn btn-accent btn-lg">
          <%= house.answeredCount > 0 ? '▶️ ' + t.continue_quiz : '🔍 ' + t.start_quiz %>
        </a>
      <% } else { %>
        <a href="/quiz/<%= house.id %>" class="btn btn-success btn-lg">✅ <%= t.view_results %></a>
      <% } %>
      <a href="/ai?house=<%= house.id %>" class="btn btn-outline">🤖 <%= lang === 'en' ? 'AI Analysis' : 'AI elemzés' %></a>
    </div>

    <!-- AI Reports (if any) -->
    <div class="card mb-6 animate-slide-up" id="ai-reports-section" style="display:none;">
      <div class="card__header d-flex justify-between items-center">
        <h3 class="card__title"><%= lang === 'en' ? 'AI Reports' : 'AI jelentések' %></h3>
        <a href="/ai?house=<%= house.id %>" class="btn btn-sm btn-outline">+ <%= lang === 'en' ? 'New Analysis' : 'Új elemzés' %></a>
      </div>
      <div class="card__body" id="ai-reports-list"></div>
    </div>
    <script>
    (function() {
      fetch('/api/ai/reports/<%= house.id %>')
        .then(function(r) { return r.json(); })
        .then(function(reports) {
          if (!reports.length) return;
          document.getElementById('ai-reports-section').style.display = 'block';
          var html = '';
          reports.forEach(function(r) {
            var badge = r.status === 'completed'
              ? '<span class="badge badge--success">✅</span>'
              : r.status === 'generating'
                ? '<span class="badge badge--warning">⏳</span>'
                : '<span class="badge badge--danger">❌</span>';
            html += '<div class="d-flex justify-between items-center mb-2" style="padding:var(--sp-2);background:var(--gray-50);border-radius:var(--radius-sm);">' +
              '<div class="d-flex items-center gap-2">' + badge + ' <span class="text-xs text-muted">' + r.created_at + '</span></div>' +
              (r.status === 'completed' ? '<a href="/ai?house=<%= house.id %>" class="btn btn-sm btn-ghost text-xs"><%= lang === "en" ? "View" : "Megtekintés" %></a>' : '') +
            '</div>';
          });
          document.getElementById('ai-reports-list').innerHTML = html;
        });
    })();
    </script>

    <!-- Inspection Progress by Category -->
    <div class="card mb-6 animate-slide-up">
      <div class="card__header">
        <h3 class="card__title"><%= t.inspection_progress %></h3>
      </div>
      <div class="card__body">
        <% groups.forEach(function(group) { %>
          <%
            var gs = house.groupScores[group.id] || { answered: 0, total: group.questionCount, score: 0 };
            var gProgress = gs.total > 0 ? Math.round((gs.answered / gs.total) * 100) : 0;
            var gScoreLevel = 'low';
            if (gs.score >= 75) gScoreLevel = 'great';
            else if (gs.score >= 50) gScoreLevel = 'good';
            else if (gs.score >= 25) gScoreLevel = 'medium';
          %>
          <div class="results-group">
            <div class="results-group__header">
              <span class="results-group__name"><%= group.name %></span>
              <span class="d-flex items-center gap-2">
                <span class="text-xs text-muted"><%= gs.answered %>/<%= gs.total %></span>
                <% if (gs.answered > 0) { %>
                  <span class="score-badge score-badge--sm" data-score-level="<%= gScoreLevel %>"><%= gs.score %>%</span>
                <% } %>
              </span>
            </div>
            <div class="score-bar score-bar--sm">
              <div class="score-bar__fill" data-score-level="<%= gScoreLevel %>" style="width: <%= gProgress %>%"></div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

    <% if (house.answeredCount > 0) { %>
      <!-- Category Scores -->
      <div class="card mb-6 animate-slide-up">
        <div class="card__header">
          <h3 class="card__title"><%= t.category_scores %></h3>
        </div>
        <div class="card__body">
          <div class="grid grid-2">
            <% groups.forEach(function(group) { %>
              <%
                var gs = house.groupScores[group.id] || { score: 0, answered: 0, total: group.questionCount, weight: group.weight };
                var gScoreLevel = 'low';
                if (gs.score >= 75) gScoreLevel = 'great';
                else if (gs.score >= 50) gScoreLevel = 'good';
                else if (gs.score >= 25) gScoreLevel = 'medium';

                var condLabel = t.poor;
                if (gs.score >= 75) condLabel = t.excellent;
                else if (gs.score >= 50) condLabel = t.good;
                else if (gs.score >= 25) condLabel = t.fair;
              %>
              <% if (gs.answered > 0) { %>
                <div class="card card--stat">
                  <div class="card__body text-center">
                    <div class="card__stat-value" style="color: var(--<%= gScoreLevel === 'great' ? 'success' : gScoreLevel === 'good' ? 'success' : gScoreLevel === 'medium' ? 'warning' : 'danger' %>)">
                      <%= gs.score %>%
                    </div>
                    <div class="card__stat-label"><%= group.name %></div>
                    <span class="badge badge--<%= gScoreLevel === 'great' ? 'success' : gScoreLevel === 'good' ? 'success' : gScoreLevel === 'medium' ? 'warning' : 'danger' %> mt-2">
                      <%= condLabel %>
                    </span>
                  </div>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Export Options -->
      <div class="card mb-6 animate-slide-up">
        <div class="card__header">
          <h3 class="card__title"><%= lang === 'en' ? 'Export' : 'Exportálás' %></h3>
        </div>
        <div class="card__body">
          <div class="export-options">
            <a href="/api/export/<%= house.id %>/pdf" class="export-option">
              <div class="export-option__icon">📄</div>
              <div class="export-option__info">
                <div class="export-option__title">PDF</div>
                <div class="export-option__desc"><%= lang === 'en' ? 'Download full inspection report' : 'Teljes szemle jelentés letöltése' %></div>
              </div>
            </a>
            <a href="/api/export/<%= house.id %>/json" class="export-option">
              <div class="export-option__icon">📋</div>
              <div class="export-option__info">
                <div class="export-option__title">JSON</div>
                <div class="export-option__desc"><%= lang === 'en' ? 'Export raw data' : 'Nyers adatok exportálása' %></div>
              </div>
            </a>
            <a href="/api/export/<%= house.id %>/csv" class="export-option">
              <div class="export-option__icon">📊</div>
              <div class="export-option__info">
                <div class="export-option__title">CSV</div>
                <div class="export-option__desc"><%= lang === 'en' ? 'Export for spreadsheet' : 'Export táblázatkezelőhöz' %></div>
              </div>
            </a>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Upload Image Modal -->
    <div class="modal-overlay" id="upload-image-modal">
      <div class="modal">
        <div class="modal__header">
          <h3 class="modal__title"><%= lang === 'en' ? 'Add Photo' : 'Fotó hozzáadása' %></h3>
          <button class="modal__close" onclick="document.getElementById('upload-image-modal').classList.remove('is-active')">&times;</button>
        </div>
        <form id="image-upload-form">
          <div class="modal__body">
            <div class="form-group">
              <label class="form-label"><%= lang === 'en' ? 'Photo' : 'Fotó' %></label>
              <input type="file" name="image" accept="image/*" class="form-control" required id="house-image-input">
            </div>
            <div class="form-group">
              <label class="form-label"><%= lang === 'en' ? 'Caption (optional)' : 'Felirat (opcionális)' %></label>
              <input type="text" name="caption" class="form-control" id="house-image-caption">
            </div>
            <div id="image-upload-preview" style="display:none;" class="mt-2">
              <img id="image-preview-img" style="max-width:100%;max-height:200px;border-radius:var(--radius);object-fit:cover;">
            </div>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('upload-image-modal').classList.remove('is-active')"><%= t.cancel %></button>
            <button type="submit" class="btn btn-primary" id="upload-image-btn"><%= lang === 'en' ? 'Upload' : 'Feltöltés' %></button>
          </div>
        </form>
      </div>
    </div>

    <!-- Edit House Modal -->
    <div class="modal-overlay" id="edit-house-modal">
      <div class="modal">
        <div class="modal__header">
          <h3 class="modal__title"><%= t.edit %> — <%= house.name %></h3>
          <button class="modal__close" onclick="document.getElementById('edit-house-modal').classList.remove('is-active')">&times;</button>
        </div>
        <form method="POST" action="/houses/<%= house.id %>">
          <div class="modal__body">
            <div class="form-group">
              <label class="form-label form-label--required" for="edit-name"><%= t.name %></label>
              <input type="text" id="edit-name" name="name" class="form-control" required value="<%= house.name %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-address"><%= t.address %></label>
              <input type="text" id="edit-address" name="address" class="form-control" value="<%= house.address || '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-price"><%= t.price %></label>
              <input type="number" id="edit-price" name="asking_price" class="form-control" min="0" step="1"
                     value="<%= house.asking_price || '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-notes"><%= t.notes %></label>
              <textarea id="edit-notes" name="notes" class="form-control" rows="3"><%= house.notes || '' %></textarea>
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-description"><%= lang === 'en' ? 'Description' : 'Leírás' %></label>
              <textarea id="edit-description" name="description" class="form-control" rows="5"><%= house.description || '' %></textarea>
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-source"><%= lang === 'en' ? 'Source' : 'Forrás' %></label>
              <select id="edit-source" name="source" class="form-control">
                <option value="manual" <%= (house.source || 'manual') === 'manual' ? 'selected' : '' %>><%= lang === 'en' ? 'Added manually' : 'Manuálisan hozzáadva' %></option>
                <option value="scraped" <%= house.source === 'scraped' ? 'selected' : '' %>><%= lang === 'en' ? 'Scraped from ingatlan.com' : 'Ingatlan.com-ról begyűjtve' %></option>
              </select>
            </div>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('edit-house-modal').classList.remove('is-active')"><%= t.cancel %></button>
            <button type="submit" class="btn btn-primary"><%= t.save %></button>
          </div>
        </form>
      </div>
    </div>

    <%- include('partials/footer') %>
  </main>
</div>
<%- include('partials/scripts') %>
<script>
  // Close modals on overlay click
  document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('is-active');
    });
  });

  // Image upload preview
  var imageInput = document.getElementById('house-image-input');
  var imagePreview = document.getElementById('image-upload-preview');
  var imagePreviewImg = document.getElementById('image-preview-img');

  if (imageInput) {
    imageInput.addEventListener('change', function() {
      if (this.files && this.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
          imagePreviewImg.src = e.target.result;
          imagePreview.style.display = 'block';
        };
        reader.readAsDataURL(this.files[0]);
      }
    });
  }

  // Image upload form
  var imageForm = document.getElementById('image-upload-form');
  if (imageForm) {
    imageForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var formData = new FormData();
      formData.append('image', imageInput.files[0]);
      formData.append('caption', document.getElementById('house-image-caption').value);

      var btn = document.getElementById('upload-image-btn');
      btn.disabled = true;
      btn.textContent = '⏳...';

      fetch('/houses/<%= house.id %>/upload-image', {
        method: 'POST',
        body: formData
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          window.location.reload();
        }
      })
      .catch(function() {
        btn.disabled = false;
        btn.textContent = '<%= lang === "en" ? "Upload" : "Feltöltés" %>';
      });
    });
  }
</script>
</body>
</html>
