<header class="header">
  <button class="hamburger" id="hamburger-toggle" aria-label="Toggle menu">
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
  </button>

  <a href="/" class="header__brand">
    🏠 <%= t.app_title %>
  </a>

  <div class="header__actions">
    <a href="<%= typeof currentUrl !== 'undefined' ? currentUrl : '/' %>?lang=hu"<%= lang === 'hu' ? ' class="font-bold"' : '' %>>HU</a>
    <a href="<%= typeof currentUrl !== 'undefined' ? currentUrl : '/' %>?lang=en"<%= lang === 'en' ? ' class="font-bold"' : '' %>>EN</a>
  </div>
</header>
