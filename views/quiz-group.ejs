<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
<div class="app">
  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <main class="main-content">

    <!-- Sticky Progress Bar -->
    <div class="quiz-progress">
      <div class="d-flex justify-between items-center mb-1">
        <span class="quiz-progress__text"><%= group.name %></span>
        <span class="quiz-progress__text"><%= answeredInGroup %> / <%= totalInGroup %> <%= t.answered %></span>
      </div>
      <div class="quiz-progress__bar">
        <div class="quiz-progress__fill" style="width: <%= totalInGroup > 0 ? Math.round((answeredInGroup / totalInGroup) * 100) : 0 %>%"></div>
      </div>
      <div class="quiz-progress__text"><%= t.group %> <%= groupIndex + 1 %> <%= t.of %> <%= totalGroups %></div>
    </div>

    <!-- Breadcrumb -->
    <div class="mb-4">
      <a href="/quiz/<%= house.id %>" class="btn btn-ghost btn-sm">← <%= t.quiz %></a>
    </div>

    <form method="POST" action="/quiz/<%= house.id %>/<%= group.id %>" id="quiz-form">
      <% group.questions.forEach(function(q, qi) { %>
        <div class="card mb-4 animate-fade-in quiz-question" id="question-<%= q.id %>">
          <div class="card__body">
            <div class="quiz-question__weight"><%= t.weight %>: <%= q.weight %></div>
            <div class="quiz-question__text"><%= qi + 1 %>. <%= q.text %>
              <% if (q.type === 'multi_choice') { %>
                <span class="badge badge--info text-xs ml-2"><%= lang === 'en' ? 'Multiple choice' : 'Több válasz' %></span>
              <% } %>
            </div>

            <!-- Options -->
            <div class="quiz-options">
              <% var isMultiChoice = q.type === 'multi_choice'; %>
              <% var selectedOptions = (q.currentAnswer && q.currentAnswer.option_id) ? q.currentAnswer.option_id.split(',') : []; %>
              <% q.options.forEach(function(opt) { %>
                <%
                  var isSelected = isMultiChoice
                    ? selectedOptions.includes(opt.id)
                    : (q.currentAnswer && q.currentAnswer.option_id === opt.id);
                  var impactClass = 'neutral';
                  var impactLabel = t.neutral;
                  if (opt.impact === 'value_increasing') { impactClass = 'positive'; impactLabel = t.value_increasing; }
                  else if (opt.impact === 'value_decreasing') { impactClass = 'negative'; impactLabel = t.value_decreasing; }
                  else if (opt.impact === 'strong_value_decreasing') { impactClass = 'negative'; impactLabel = t.strong_value_decreasing; }
                %>
                <label class="quiz-option<%= isSelected ? ' is-selected' : '' %>"
                       data-house-id="<%= house.id %>"
                       data-question-id="<%= q.id %>">
                  <input type="<%= isMultiChoice ? 'checkbox' : 'radio' %>"
                         name="option_<%= q.id %>"
                         value="<%= opt.id %>"
                         <%= isSelected ? 'checked' : '' %>
                         style="display:none">
                  <div class="quiz-option__<%= isMultiChoice ? 'checkbox' : 'radio' %>"></div>
                  <div class="quiz-option__label">
                    <div><%= opt.text %></div>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                      <span class="quiz-option__impact quiz-option__impact--<%= impactClass %>"><%= impactLabel %></span>
                      <span class="text-xs text-muted"><%= t.score %>: <%= opt.score %>/10</span>
                      <% if (opt.estimatedCost) { %>
                        <span class="text-xs text-muted">💰 <%= t.estimated_cost %>: <%= opt.estimatedCost %></span>
                      <% } %>
                    </div>
                  </div>
                </label>
              <% }); %>
            </div>

            <!-- Notes & Image Actions (aligned row) -->
            <div class="quiz-question__actions">
              <button type="button" class="btn btn-sm btn-ghost quiz-toggle-notes" data-target="notes-<%= q.id %>">
                📝 <%= t.add_notes %><%= q.currentAnswer && q.currentAnswer.notes ? ' ✓' : '' %>
              </button>
              <% if (q.allowImage) { %>
                <button type="button" class="btn btn-sm btn-ghost quiz-toggle-image" data-target="image-<%= q.id %>">
                  📷 <%= t.upload_image %><%= q.currentAnswer && q.currentAnswer.image_path ? ' ✓' : '' %>
                </button>
              <% } %>
              <span class="quiz-save-indicator" id="save-indicator-<%= q.id %>">✅ <%= lang === 'en' ? 'Saved' : 'Mentve' %></span>
            </div>

            <!-- Notes (hidden behind toggle) -->
            <div class="quiz-notes-wrapper" id="notes-<%= q.id %>" style="display:<%= q.currentAnswer && q.currentAnswer.notes ? 'block' : 'none' %>;">
              <textarea name="notes_<%= q.id %>"
                        class="form-control quiz-notes-input mt-2"
                        rows="2"
                        placeholder="<%= t.add_notes %>"
                        data-house-id="<%= house.id %>"
                        data-question-id="<%= q.id %>"><%= q.currentAnswer && q.currentAnswer.notes ? q.currentAnswer.notes : '' %></textarea>
            </div>

            <!-- Image Upload (hidden behind toggle) -->
            <% if (q.allowImage) { %>
              <div class="quiz-image-wrapper" id="image-<%= q.id %>" style="display:<%= q.currentAnswer && q.currentAnswer.image_path ? 'block' : 'none' %>;">
                <% if (q.currentAnswer && q.currentAnswer.image_path) { %>
                  <div class="mb-2 mt-2">
                    <img src="/uploads/<%= q.currentAnswer.image_path %>"
                         alt="<%= q.text %>"
                         class="quiz-image-preview"
                         data-lightbox="quiz-images"
                         data-caption="<%= q.text %>"
                         title="<%= lang === 'en' ? 'Click to view full size' : 'Kattintson a nagyításhoz' %>">
                  </div>
                <% } %>

                <!-- House images picker for office use -->
                <% if (typeof houseImages !== 'undefined' && houseImages && houseImages.length > 0) { %>
                  <div class="mt-2 mb-2">
                    <div class="text-xs text-muted mb-1"><%= lang === 'en' ? 'Attach from house photos:' : 'Csatolás ház fotókból:' %></div>
                    <div class="d-flex flex-wrap gap-2">
                      <% houseImages.forEach(function(hi) { %>
                        <button type="button"
                             class="quiz-attach-house-img"
                             style="width:60px;height:60px;padding:0;background:none;border:2px solid transparent;border-radius:var(--radius-sm);cursor:pointer;transition:border-color 0.2s;overflow:hidden;"
                             data-filename="<%= hi.filename %>"
                             data-house-id="<%= house.id %>"
                             data-question-id="<%= q.id %>"
                             title="<%= lang === 'en' ? 'Attach this image' : 'Kép csatolása' %>"
                             onclick="attachHouseImage(this)">
                          <img src="/uploads/<%= hi.filename %>"
                               style="width:100%;height:100%;object-fit:cover;display:block;"
                               alt="<%= lang === 'en' ? 'Attach this image' : 'Kép csatolása' %>">
                        </button>
                      <% }); %>
                    </div>
                  </div>
                <% } %>

                <label class="quiz-upload mt-2" data-house-id="<%= house.id %>" data-question-id="<%= q.id %>">
                  📷 <%= t.upload_image %>
                  <input type="file"
                         accept="image/*"
                         style="display:none"
                         class="quiz-image-input"
                         data-house-id="<%= house.id %>"
                         data-question-id="<%= q.id %>">
                </label>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>

      <!-- Navigation -->
      <div class="quiz-nav">
        <div>
          <% if (prevGroup) { %>
            <a href="/quiz/<%= house.id %>/<%= prevGroup.id %>" class="btn btn-secondary">← <%= t.prev %></a>
          <% } %>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" name="action" value="save" class="btn btn-primary"><%= t.save %></button>
          <% if (nextGroup) { %>
            <input type="hidden" name="nextGroup" value="<%= nextGroup.id %>">
            <button type="submit" name="action" value="next" class="btn btn-accent"><%= t.next %> →</button>
          <% } else { %>
            <a href="/quiz/<%= house.id %>/results" class="btn btn-accent"><%= t.finish %> →</a>
          <% } %>
        </div>
      </div>
    </form>

    <%- include('partials/footer') %>
  </main>
</div>
<%- include('partials/scripts') %>
<script>
(function() {
  // Show save indicator for a question
  function flashSaved(questionId) {
    var indicator = document.getElementById('save-indicator-' + questionId);
    if (indicator) {
      indicator.classList.add('is-visible');
      setTimeout(function() { indicator.classList.remove('is-visible'); }, 2000);
    }
  }

  // Toggle notes visibility
  document.querySelectorAll('.quiz-toggle-notes').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = document.getElementById(this.dataset.target);
      if (target) {
        target.style.display = target.style.display === 'none' ? 'block' : 'none';
        if (target.style.display === 'block') {
          target.querySelector('textarea').focus();
        }
      }
    });
  });

  // Toggle image upload visibility
  document.querySelectorAll('.quiz-toggle-image').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = document.getElementById(this.dataset.target);
      if (target) {
        target.style.display = target.style.display === 'none' ? 'block' : 'none';
      }
    });
  });

  // Auto-save on option change (AJAX) - handles both radio and checkbox
  document.querySelectorAll('.quiz-option input[type="radio"], .quiz-option input[type="checkbox"]').forEach(function(input) {
    input.addEventListener('change', function() {
      var label = this.closest('.quiz-option');
      var houseId = label.dataset.houseId;
      var questionId = label.dataset.questionId;
      var isCheckbox = this.type === 'checkbox';

      var parent = this.closest('.quiz-options');

      if (isCheckbox) {
        // Multi-choice: collect all checked values
        var checked = parent.querySelectorAll('input[type="checkbox"]:checked');
        var optionIds = [];
        checked.forEach(function(cb) { optionIds.push(cb.value); });
        var optionId = optionIds.join(',');

        // Update visual state for checkboxes
        parent.querySelectorAll('.quiz-option').forEach(function(opt) {
          var cb = opt.querySelector('input[type="checkbox"]');
          if (cb && cb.checked) {
            opt.classList.add('is-selected');
          } else {
            opt.classList.remove('is-selected');
          }
        });

        fetch('/quiz/' + houseId + '/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionId: questionId, optionId: optionId })
        }).then(function(r) {
          return r.json();
        }).then(function(data) {
          if (data.success) {
            flashSaved(questionId);
            window.showToast('<%= lang === "en" ? "Answer saved" : "Válasz mentve" %>', 'success', 1500);
          }
        }).catch(function() {
          window.showToast('<%= lang === "en" ? "Save failed" : "Mentés sikertelen" %>', 'error');
        });
      } else {
        // Single choice
        var optionId = this.value;
        parent.querySelectorAll('.quiz-option').forEach(function(opt) {
          opt.classList.remove('is-selected');
        });
        label.classList.add('is-selected');

        fetch('/quiz/' + houseId + '/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionId: questionId, optionId: optionId })
        }).then(function(r) {
          return r.json();
        }).then(function(data) {
          if (data.success) {
            flashSaved(questionId);
            window.showToast('<%= lang === "en" ? "Answer saved" : "Válasz mentve" %>', 'success', 1500);
          }
        }).catch(function() {
          window.showToast('<%= lang === "en" ? "Save failed" : "Mentés sikertelen" %>', 'error');
        });
      }
    });
  });

  // Auto-save notes on blur
  document.querySelectorAll('.quiz-notes-input').forEach(function(textarea) {
    textarea.addEventListener('blur', function() {
      var houseId = this.dataset.houseId;
      var questionId = this.dataset.questionId;
      var notes = this.value;
      var form = document.getElementById('quiz-form');
      var checkedInputs = form.querySelectorAll('input[name="option_' + questionId + '"]:checked');
      var optionId = null;
      if (checkedInputs.length > 1) {
        var ids = [];
        checkedInputs.forEach(function(ci) { ids.push(ci.value); });
        optionId = ids.join(',');
      } else if (checkedInputs.length === 1) {
        optionId = checkedInputs[0].value;
      }

      fetch('/quiz/' + houseId + '/answer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ questionId: questionId, optionId: optionId, notes: notes })
      }).then(function(r) {
        return r.json();
      }).then(function(data) {
        if (data.success) {
          flashSaved(questionId);
          window.showToast('<%= lang === "en" ? "Notes saved" : "Jegyzet mentve" %>', 'success', 1500);
        }
      }).catch(function() {
        window.showToast('<%= lang === "en" ? "Save failed" : "Mentés sikertelen" %>', 'error');
      });
    });
  });

  // Image upload
  function handleImageUpload(input) {
    var houseId = input.dataset.houseId;
    var questionId = input.dataset.questionId;
    var file = input.files[0];
    if (!file) return;

    var formData = new FormData();
    formData.append('image', file);

    var uploadLabel = input.closest('.quiz-upload');
    uploadLabel.textContent = '⏳ ...';

    fetch('/quiz/' + encodeURIComponent(houseId) + '/upload/' + encodeURIComponent(questionId), {
      method: 'POST',
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var container = uploadLabel.parentElement;
        var existingImg = container.querySelector('img.quiz-image-preview');
        if (existingImg) {
          existingImg.src = '/uploads/' + data.filename;
        } else {
          var wrapper = document.createElement('div');
          wrapper.className = 'mb-2 mt-2';
          var img = document.createElement('img');
          img.src = '/uploads/' + data.filename;
          img.className = 'quiz-image-preview';
          img.dataset.lightbox = 'quiz-images';
          img.title = '<%= lang === "en" ? "Click to view full size" : "Kattintson a nagyításhoz" %>';
          wrapper.appendChild(img);
          container.insertBefore(wrapper, uploadLabel);
        }
        // Rebuild the upload label
        while (uploadLabel.firstChild) uploadLabel.removeChild(uploadLabel.firstChild);
        uploadLabel.appendChild(document.createTextNode('📷 <%= t.upload_image %>'));
        var newInput = document.createElement('input');
        newInput.type = 'file';
        newInput.accept = 'image/*';
        newInput.style.display = 'none';
        newInput.className = 'quiz-image-input';
        newInput.dataset.houseId = houseId;
        newInput.dataset.questionId = questionId;
        newInput.addEventListener('change', function() { handleImageUpload(this); });
        uploadLabel.appendChild(newInput);
        window.showToast('<%= lang === "en" ? "Image uploaded" : "Kép feltöltve" %>', 'success');
        flashSaved(questionId);
      }
    })
    .catch(function() {
      uploadLabel.textContent = '📷 <%= t.upload_image %>';
      window.showToast('<%= lang === "en" ? "Upload failed" : "Feltöltés sikertelen" %>', 'error');
    });
  }

  document.querySelectorAll('.quiz-image-input').forEach(function(input) {
    input.addEventListener('change', function() { handleImageUpload(this); });
  });

  // Attach house image to quiz question
  window.attachHouseImage = function(imgEl) {
    var filename = imgEl.dataset.filename;
    var houseId = imgEl.dataset.houseId;
    var questionId = imgEl.dataset.questionId;

    imgEl.style.borderColor = 'var(--accent)';
    imgEl.style.opacity = '0.6';

    fetch('/quiz/' + encodeURIComponent(houseId) + '/attach-image/' + encodeURIComponent(questionId), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ filename: filename })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        imgEl.style.borderColor = 'var(--success)';
        imgEl.style.opacity = '1';
        // Update or create preview
        var wrapper = imgEl.closest('.quiz-image-wrapper');
        var existingImg = wrapper.querySelector('img.quiz-image-preview');
        if (existingImg) {
          existingImg.src = '/uploads/' + filename;
        } else {
          var div = document.createElement('div');
          div.className = 'mb-2 mt-2';
          var img = document.createElement('img');
          img.src = '/uploads/' + filename;
          img.className = 'quiz-image-preview';
          img.dataset.lightbox = 'quiz-images';
          div.appendChild(img);
          wrapper.insertBefore(div, wrapper.firstChild);
        }
        window.showToast('<%= lang === "en" ? "Image attached" : "Kép csatolva" %>', 'success');
        flashSaved(questionId);
      }
    })
    .catch(function() {
      imgEl.style.borderColor = 'transparent';
      imgEl.style.opacity = '1';
      window.showToast('<%= lang === "en" ? "Attach failed" : "Csatolás sikertelen" %>', 'error');
    });
  };
})();
</script>
</body>
</html>
